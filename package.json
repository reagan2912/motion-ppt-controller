    "pdfjs-dist": "^4.4.168"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "vitest": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "prettier": "^3",
    "husky": "^9",
    "lint-staged": "^15"
  }
}
